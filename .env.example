# Copie este arquivo para ".env" e preencha com os valores reais.
# O .env de verdade nunca é enviado pro GitHub (está no .gitignore).

# Connection string do Supabase: Project Settings > Database > Connection string.
# Use o modo "Transaction pooler" (porta 6543) para o back-end hospedado (Render/Railway/etc).
DATABASE_URL=postgresql+pg8000://postgres.xxxxxxxxxxxx:sua_senha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

SECRET_KEY=troque_por_uma_chave_aleatoria_bem_grande_em_producao
ALGORITMO=HS256
TOKEN_EXPIRA_MINUTOS=60

# URLs do front-end que podem chamar essa API (separadas por vírgula)
ORIGENS_PERMITIDAS=http://localhost:5173,https://seu-projeto.vercel.app
